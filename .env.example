NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=weight_tracker
DB_SSL=false

# Force TypeORM schema sync (true on first production deploy, false afterwards)
DB_SYNC=false

# JWT — use a long random string in production
JWT_SECRET=change-this-to-a-very-secure-random-secret
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins (leave empty to allow all in dev)
# Example: https://weight-tracker.vercel.app
ALLOWED_ORIGINS=
